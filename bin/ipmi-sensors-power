#!/bin/sh
# Emits the power subset of `ipmitool sensor list` as a
# Redfish Power.v1 JSON envelope: { Voltages: [...],
# PowerSupplies: [...] }. Companion to
# ipmi-sensors-thermal; same parsing strategy, different
# unit filter.
#
# Usage:
#   ipmi-sensors-power <id>
#
# <id> selects the BMC from /app/config/bmcs.yaml (the
# Redfish member id from the /Chassis/{id}/Power route). It's
# threaded through to ipmi-env for connection-arg resolution
# AND into the per-reading `@odata.id` fragments below so a
# member's Voltages/PowerSupplies anchor at its own Chassis.
#
# Filter rule:
#   "Volts" units             -> Voltages
#   "Watts" units, "PSU"/"PS" in name -> PowerSupplies
# Everything else is left for ipmi-sensors-thermal.
set -eu

# ipmi-env reads the BMC id from $1; sourcing keeps our $@.
. /app/bin/ipmi-env

# Export the id so it reaches the python parser on the RIGHT of
# the pipe: a `VAR=x cmd | other` prefix scopes VAR to the LEFT
# command (ipmitool) only, so the parser would KeyError on
# os.environ["SALMON_BMC_ID"]. The id anchors each reading's
# `@odata.id` at /Chassis/<id>/Power, not a literal 1.
export SALMON_BMC_ID="$1"
ipmitool $IPMITOOL_AUTH sensor list | /usr/local/bin/python3 -c '
import json, os, sys

bmc_id = os.environ["SALMON_BMC_ID"]

voltages = []
psus     = []
for line in sys.stdin:
    parts = [p.strip() for p in line.split("|")]
    if len(parts) < 4:
        continue
    name, value, unit, status = parts[0], parts[1], parts[2], parts[3]
    if value in ("na", "0x0", ""):
        continue
    try:
        reading = float(value)
    except ValueError:
        continue
    member_id = name.replace(" ", "_").replace("/", "_")
    if "Volts" in unit:
        voltages.append({
            "@odata.id":      f"/redfish/v1/Chassis/{bmc_id}/Power#/Voltages/{member_id}",
            "MemberId":       member_id,
            "Name":           name,
            "ReadingVolts":   reading,
            "Status":         {"State": "Enabled" if status == "ok" else "Disabled"},
        })
    elif "Watts" in unit and ("PSU" in name.upper() or name.upper().startswith("PS")):
        psus.append({
            "@odata.id":      f"/redfish/v1/Chassis/{bmc_id}/Power#/PowerSupplies/{member_id}",
            "MemberId":       member_id,
            "Name":           name,
            "PowerInputWatts": reading,
            "Status":         {"State": "Enabled" if status == "ok" else "Disabled"},
        })

json.dump({"Voltages": voltages, "PowerSupplies": psus}, sys.stdout)
'
